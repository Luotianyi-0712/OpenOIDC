# Server
OIDC_SERVER_HOST=0.0.0.0
OIDC_SERVER_PORT=8080
OIDC_SERVER_ISSUER=http://localhost:8080
OIDC_SERVER_PUBLIC_URL=http://localhost:8080
OIDC_SERVER_READ_TIMEOUT=15s
OIDC_SERVER_WRITE_TIMEOUT=15s

# Docker image
OIDC_IMAGE=ghcr.io/luotianyi-0712/openoidc:latest

# Database (PostgreSQL)
OIDC_DATABASE_HOST=localhost
OIDC_DATABASE_PORT=5432
OIDC_DATABASE_USER=oidc
OIDC_DATABASE_PASSWORD=oidc_secret
OIDC_DATABASE_NAME=oidc
OIDC_DATABASE_SSLMODE=disable
OIDC_DATABASE_MAX_CONNS=20
OIDC_DATABASE_MIN_CONNS=2

# Redis
OIDC_REDIS_HOST=localhost
OIDC_REDIS_PORT=6379
OIDC_REDIS_PASSWORD=
OIDC_REDIS_DB=0

# JWT / Signing
OIDC_JWT_ALGORITHM=RS256
OIDC_JWT_ACCESS_TOKEN_TTL=1h
OIDC_JWT_REFRESH_TOKEN_TTL=720h
OIDC_JWT_ID_TOKEN_TTL=1h
OIDC_JWT_AUTH_CODE_TTL=10m
OIDC_JWT_KEY_ROTATION_DAYS=30

# Session
OIDC_SESSION_COOKIE_NAME=oidc_session
OIDC_SESSION_COOKIE_DOMAIN=
OIDC_SESSION_COOKIE_SECURE=false
OIDC_SESSION_TTL=720h

# Admin Bootstrap
OIDC_ADMIN_EMAIL=admin@example.com
OIDC_ADMIN_PASSWORD=change_me_now

# Logging
OIDC_LOG_LEVEL=info
OIDC_LOG_FORMAT=json

# Secrets
OIDC_SECRETS_CLIENT_SECRET_ENCRYPTION_KEY=dev-client-secret-encryption-key

# OAuth2 Providers (examples - leave blank to disable)
OIDC_OAUTH2_GOOGLE_CLIENT_ID=
OIDC_OAUTH2_GOOGLE_CLIENT_SECRET=
OIDC_OAUTH2_GITHUB_CLIENT_ID=
OIDC_OAUTH2_GITHUB_CLIENT_SECRET=
OIDC_OAUTH2_MICROSOFT_CLIENT_ID=
OIDC_OAUTH2_MICROSOFT_CLIENT_SECRET=
OIDC_OAUTH2_APPLE_CLIENT_ID=
OIDC_OAUTH2_APPLE_TEAM_ID=
OIDC_OAUTH2_APPLE_KEY_ID=
OIDC_OAUTH2_APPLE_PRIVATE_KEY=
OIDC_OAUTH2_FACEBOOK_CLIENT_ID=
OIDC_OAUTH2_FACEBOOK_CLIENT_SECRET=
OIDC_OAUTH2_TWITTER_CLIENT_ID=
OIDC_OAUTH2_TWITTER_CLIENT_SECRET=
OIDC_OAUTH2_LINKEDIN_CLIENT_ID=
OIDC_OAUTH2_LINKEDIN_CLIENT_SECRET=
OIDC_OAUTH2_WECHAT_APP_ID=
OIDC_OAUTH2_WECHAT_APP_SECRET=
OIDC_OAUTH2_QQ_APP_ID=
OIDC_OAUTH2_QQ_APP_KEY=
OIDC_OAUTH2_WEIBO_CLIENT_ID=
OIDC_OAUTH2_WEIBO_CLIENT_SECRET=
OIDC_OAUTH2_DINGTALK_CLIENT_ID=
OIDC_OAUTH2_DINGTALK_CLIENT_SECRET=

# SMS Provider (for phone verification)
OIDC_SMS_PROVIDER=mock
OIDC_SMS_ACCESS_KEY=
OIDC_SMS_ACCESS_SECRET=
OIDC_SMS_SIGN_NAME=
OIDC_SMS_TEMPLATE_CODE=
